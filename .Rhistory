type_groups <- c(unique(mdf.ps.sid$Majority_ITS2_collapsed))
# Create a color object for the specified data
col.mdf.ps.sid <- create_color_dfs(mdf.ps.sid, top_orientation = FALSE,group_level="Majority_ITS2_collapsed",subgroup_level="ITS2_type_profile",selected_groups=c("D1","B5-1*","B5-2*","B5/B19","B19"),cvd=TRUE)
# Extract
col.mdf.ps.sid.m <- col.mdf.ps.sid$mdf
col.mdf.ps.sid.c <- col.mdf.ps.sid$cdf
col.mdf.ps.sid.m.lk1 <- subset(col.mdf.ps.sid.m,site=="LK1")
col.mdf.ps.sid.m.lk1$time <- factor(col.mdf.ps.sid.m.lk1$time,levels=c("Pre","Irma","Post"))
plot_microshades(col.mdf.ps.sid.m.lk1, col.mdf.ps.sid.c)+
facet_wrap(zone~time,scales="free_x")+
theme_cowplot()+
theme(axis.text.x=element_blank())
